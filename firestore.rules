rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // evaluations: teachers can read/write; students can only read their own
    // Students can also create their own evaluation docs during registration
    match /evaluations/{evalId} {
      allow read: if request.auth != null
        && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "teacher"
          || resource.data.studentUid == request.auth.uid
        );
      allow create: if request.auth != null
        && request.resource.data.studentUid == request.auth.uid;
      allow update, delete: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "teacher";
    }

    // users: teachers can read/write all; students can only read their own document
    match /users/{uid} {
      // A user can always read their own document (avoids deadlock when doc doesn't exist yet)
      allow read: if request.auth != null
        && (
          request.auth.uid == uid
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "teacher"
        );
      // A user can create their own document (registration flow)
      allow create: if request.auth != null && request.auth.uid == uid;
      // Only teachers can update/delete user documents
      allow update, delete: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "teacher";
    }

    // outbox: authenticated users can read/write (system events)
    match /outbox/{entryId} {
      allow read, write: if request.auth != null;
    }
  }
}
