rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // evaluations: teachers can read/write; students can only read their own
    match /evaluations/{evalId} {
      allow read: if request.auth != null
        && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "teacher"
          || resource.data.studentUid == request.auth.uid
        );
      allow create: if request.auth != null
        && (
          request.resource.data.studentUid == request.auth.uid
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "teacher"
        );
      allow update, delete: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "teacher";
    }

    // users: teachers can read/write all; students can only read their own document
    match /users/{uid} {
      // A user can always read their own document (avoids deadlock when doc doesn't exist yet)
      allow read: if request.auth != null
        && (
          request.auth.uid == uid
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "teacher"
        );
      // A user can create their own document (registration flow)
      allow create: if request.auth != null && request.auth.uid == uid;
      // Only teachers can update/delete user documents
      allow update, delete: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "teacher";
    }

    // outbox: authenticated users can read/write (system events)
    match /outbox/{entryId} {
      allow read, write: if request.auth != null;
    }

    // config: teachers can read/write; any authenticated user can read
    match /config/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "teacher";
    }

    // attendance: teachers can create/update sessions; students can read their own records
    match /attendance/{classId} {
      allow read: if request.auth != null
        && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "teacher"
          || resource.data.presentStudents.hasAny([request.auth.uid])
        );
      allow create: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "teacher";
      allow update: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "teacher";
      allow delete: if false;
    }
  }
}
