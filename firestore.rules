rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isTeacher() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "teacher";
    }

    function isPlayableAvatarClass(value) {
      return value in ['berserker', 'guerrero', 'maga', 'arquera', 'asesina', 'paladin', 'sacerdote'];
    }

    // evaluations: teachers can read/write; students can only read their own
    match /evaluations/{evalId} {
      allow read: if request.auth != null
        && (
          isTeacher()
          || resource.data.studentUid == request.auth.uid
        );
      allow create: if request.auth != null
        && (
          request.resource.data.studentUid == request.auth.uid
          || isTeacher()
        );
      allow update, delete: if request.auth != null && isTeacher();
    }

    // users: teachers can read/write all; students can only read their own document
    match /users/{uid} {
      allow read: if request.auth != null
        && (
          request.auth.uid == uid
          || isTeacher()
        );
      allow create: if request.auth != null && (request.auth.uid == uid || isTeacher());
      // Teachers can update/delete any user doc.
      // Students can update only XP-related fields on their own doc (needed for attendance self-registration).
      allow update: if request.auth != null
        && (
          isTeacher()
          || (
            request.auth.uid == uid
            && (
              request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['xp', 'level', 'xpToNextLevel', 'processedEvalIds'])
              || (
                request.resource.data.diff(resource.data).affectedKeys().hasOnly(['avatarClass'])
                && (
                  !("avatarClass" in resource.data)
                  || resource.data.avatarClass == null
                )
                && isPlayableAvatarClass(request.resource.data.avatarClass)
              )
            )
          )
        );
      allow delete: if request.auth != null && isTeacher();
    }

    // outbox: authenticated users can read/write (system events)
    match /outbox/{entryId} {
      allow read, write: if request.auth != null;
    }

    // config: teachers can read/write; any authenticated user can read
    match /config/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isTeacher();
    }

    // attendance: teachers can manage sessions; students can self-register within the configured window
    match /attendance/{classId} {
      allow read: if request.auth != null
        && (
          isTeacher()
          || resource.data.presentStudents.hasAny([request.auth.uid])
          || resource.data.selfRegistration == true
        );
      allow create: if request.auth != null && isTeacher();
      allow update: if request.auth != null
        && (
          isTeacher()
          || (
            // Student may only add their own UID to presentStudents within the configured window
            resource.data.selfRegistration == true
            && request.time >= resource.data.windowStart
            && request.time <= resource.data.windowEnd
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['presentStudents'])
            && request.resource.data.presentStudents.hasAll(resource.data.presentStudents)
            && request.resource.data.presentStudents
                .removeAll(resource.data.presentStudents)
                .hasOnly([request.auth.uid])
          )
        );
      allow delete: if request.auth != null && isTeacher();
    }
  }
}
