rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // evaluations: teachers can read/write; students can only read their own
    match /evaluations/{evalId} {
      allow read: if request.auth != null
        && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "teacher"
          || resource.data.studentUid == request.auth.uid
        );
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "teacher";
    }

    // users: teachers can read/write; students can only read their own document
    match /users/{uid} {
      allow read: if request.auth != null
        && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "teacher"
          || request.auth.uid == uid
        );
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "teacher";
    }

    // outbox: authenticated users can read/write their own entries
    match /outbox/{entryId} {
      allow read, write: if request.auth != null
        && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null;
    }
  }
}
